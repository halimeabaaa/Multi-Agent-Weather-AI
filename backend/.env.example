# Veritabanı
DB_NAME=weather_ai
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# API anahtarları
WEATHER_API_KEY=
OPENAI_API_KEY=
DJANGO_SECRET_KEY=

# Frontend adresi (şifre sıfırlama linki buraya gider)
# Docker nginx: http://localhost:3000
# Live Server:  http://127.0.0.1:5500
FRONTEND_URL=http://localhost:3000

# Gmail SMTP — normal şifre DEĞİL, "Uygulama Şifresi" kullanın
# https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=Weather AI <your.email@gmail.com>
